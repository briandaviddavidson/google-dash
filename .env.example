# Copy to .env (or run `npm run config` to generate). Vite exposes VITE_* to the frontend.
#
# To boot the app you only NEED a Google Maps API key (below). With
# STORAGE_BACKEND=memory the app runs with no GCP project or database — annotations
# just aren't persisted across restarts. Switch to firestore/gcs for real persistence.

# --- Frontend (Vite) ---
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-browser-key
VITE_API_BASE_URL=http://localhost:3000
VITE_TITLE=Google Dash
VITE_DESCRIPTION=A situational-awareness dashboard
VITE_LOGO=/logo.svg
VITE_FAVICON=/favicon.ico

# --- Server (Cloud Run) ---
PORT=3000
GCP_PROJECT_ID=your-gcp-project-id
# memory (no GCP needed) | firestore | gcs
STORAGE_BACKEND=memory
# Firestore path
FIRESTORE_COLLECTION=annotations
# Cloud Storage path (used when STORAGE_BACKEND=gcs)
GCS_BUCKET=your-bucket-name
GCS_OBJECT=annotations.geojson
# For local dev against the Firestore emulator:
# FIRESTORE_EMULATOR_HOST=localhost:8080
